///
/// bmsg.scl -- Binary message protocol
///
include once;
include "char64.scl";
include "modem.scl";

type bmsg_raw_t struct {
    pref  char64_t;
    kind  char64_t;
    seq   int32;
    len   int16;
    flags int16;
    data  *void;
}

func bmsg_recv() *bmsg_raw_t;
func bmsg_send(msg *bmsg_raw_t) mdm_err_t;

