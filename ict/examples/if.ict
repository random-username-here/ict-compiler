///
/// Conditional branching
///

func_decl @main () void;

func_impl @main {
%start:
    %cond       Const 1;
                Bc %cond %then %else;
%then:
                DebugPrint 1;
                Br %end;
%else:
                DebugPrint 0;
                Br %end;
%end:
                DebugPrint 2;
                Ret;
}
