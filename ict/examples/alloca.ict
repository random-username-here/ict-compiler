///
/// Allocating a place on stack, storing and printing from it.
///

func_decl @main () void;

func_impl @main {
    %addr       Alloca[i64];
    %val        Const 42;
                Store[i64] %addr %val;
    %read       Load[i64] %addr;
                DebugPrint %read;
                Ret;
}
